# Nerdy Gamer Tools — production: http://ngt.dackdns.ddns.net/
# Document root = project folder (index.php, .htaccess, STYLE/, the_files/).

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?page=$1 [L,QSA]
</IfModule>
